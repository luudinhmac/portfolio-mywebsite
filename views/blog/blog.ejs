<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog - Lưu Đình Mác</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .blog-header { background: #1e293b; color: white; padding: 40px 20px 30px; text-align: center; }
        .blog-header h1 { font-size: 2.2rem; margin-bottom: 10px; }
        .blog-header p { color: #94a3b8; font-size: 1.1rem; max-width: 600px; margin: 0 auto; }
        
        .blog-container { max-width: 1100px; margin: 50px auto; padding: 0 20px; display: grid; grid-template-columns: 3fr 1fr; gap: 40px; }
        
        .post-card {
            background: #fff; border-radius: 12px; border: 1px solid #e2e8f0;
            padding: 30px; margin-bottom: 30px; transition: all 0.3s;
            position: relative;
        }
        .post-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1); border-color: #cbd5e1; }
        
        .post-meta { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; font-size: 0.9rem; color: #64748b; }
        .tag-category { background: #e0f2fe; color: #0284c7; padding: 4px 12px; border-radius: 20px; font-weight: 600; }
        .tag-series { background: #fef08a; color: #854d0e; padding: 4px 12px; border-radius: 20px; font-weight: 600; }
        .post-pinned { position: absolute; top: 30px; right: 30px; color: #f59e0b; font-size: 1.5rem; }
        
        .post-title { font-size: 1.8rem; font-weight: 700; color: #1e293b; margin-bottom: 10px; }
        .post-title a { transition: color 0.2s; }
        .post-title a:hover { color: #2563eb; }
        
        .sidebar { padding: 30px; background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; height: fit-content; }
        .sidebar h3 { font-size: 1.1rem; margin-bottom: 20px; border-bottom: 2px solid #2563eb; padding-bottom: 8px; display: inline-block; }
        .category-list li { margin-bottom: 12px; }
        .category-list a { color: #475569; font-weight: 500; transition: color 0.2s; }
        .category-list a:hover, .category-list a.active { color: #2563eb; }

        .search-widget { margin-bottom: 30px; position: relative; }
        .search-widget input { 
            width: 100%; padding: 12px 15px; border: 1px solid #e2e8f0; border-radius: 8px; 
            outline: none; transition: border-color 0.2s;
        }
        .search-widget input:focus { border-color: #2563eb; }
        .search-spinner { position: absolute; right: 12px; top: 48px; display: none; color: #2563eb; }

        .post-title { font-size: 1.4rem !important; line-height: 1.4 !important; margin-bottom: 15px; }

        .eng-item { font-size: 0.85rem; color: #94a3b8; margin-right: 15px; display: inline-flex; align-items: center; gap: 4px; }
        .eng-item i { font-size: 0.9rem; }
        
        .active-filter-badge { 
            display: inline-flex; align-items: center; gap: 8px; 
            background: #eff6ff; color: #2563eb; padding: 8px 16px; 
            border-radius: 8px; font-weight: 600; margin-bottom: 20px; font-size: 0.9rem;
        }
        .active-filter-badge a { color: #ef4444; margin-left: 5px; }
        
        @media (max-width: 768px) {
            .blog-container { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body class="bg-light">

    <%- include('../partials/header') %>

    <!-- Header -->
    <header class="blog-header">
        <h1>Tech Blog & Kiến Thức</h1>
        <p>Chia sẻ kiến thức, kinh nghiệm và góc nhìn về DevOps, Linux, Ảo hóa và công việc System Engineer.</p>
    </header>

    <div class="blog-container">
        <!-- Main Content (Posts) -->
        <main id="posts-list">
            <% if (Object.keys(filters || {}).length > 0) { %>
                <div class="active-filter-badge">
                    <span><i class="fas fa-filter"></i> Đang lọc kết quả</span>
                    <a href="/blog" title="Xóa lọc"><i class="fas fa-times-circle"></i></a>
                </div>
            <% } %>

            <% if (posts.length === 0) { %>
                <div style="text-align:center; padding: 40px; background:#fff; border-radius:12px; border:1px dashed #cbd5e1;">
                    <i class="fas fa-search" style="font-size:2rem; color:#94a3b8; display:block; margin-bottom:15px;"></i>
                    <p style="color:#64748b;">Không tìm thấy bài viết nào phù hợp.</p>
                </div>
            <% } else { %>
                <% posts.forEach(post => { %>
                    <article class="post-card">
                        <% if (post.is_pinned) { %>
                            <i class="fas fa-thumbtack post-pinned" title="Bài ghim"></i>
                        <% } %>
                        <div class="post-meta">
                            <a href="/blog?category=<%= encodeURIComponent(post.category || '') %>" class="tag-category"><%= post.category || 'Không phân loại' %></a>
                            <% if (post.series) { %>
                                <a href="/blog?series=<%= encodeURIComponent(post.series) %>" class="tag-series"><i class="fas fa-layer-group"></i> <%= post.series %></a>
                            <% } %>
                            <a href="/blog?author=<%= post.author_id %>" style="color: #64748b;"><i class="far fa-user"></i> <%= post.author_name || 'Admin' %></a>
                            <span><i class="far fa-calendar-alt"></i> <%= new Date(post.created_at).toLocaleDateString('vi-VN') %></span>
                        </div>
                        <h2 class="post-title"><a href="/post/<%= post.id %>"><%= post.title %></a></h2>
                        <div class="engagement-bar">
                            <span class="eng-item"><i class="far fa-eye"></i> <%= post.views || 0 %></span>
                            <span class="eng-item"><i class="far fa-heart"></i> <%= post.likes || 0 %></span>
                            <span class="eng-item"><i class="far fa-comment"></i> <%= post.comment_count || 0 %></span>
                        </div>
                    </article>
                <% }) %>
            <% } %>
        </main>
        
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="search-widget">
                <h3>Tìm Kiếm</h3>
                <div class="search-box">
                    <input type="text" id="searchInput" placeholder="Tìm tiêu đề, tác giả, nội dung..." value="<%= filters ? (filters.search || '') : '' %>">
                    <i class="fas fa-spinner fa-spin search-spinner" id="searchSpinner"></i>
                </div>
            </div>

            <h3>Danh Mục</h3>
            <ul class="category-list">
                <li><a href="/blog" class="<%= !filters || !filters.category ? 'active' : '' %>">Tất cả bài viết</a></li>
                <% 
                   const uniqueCats = Array.from(new Set(posts.map(p => p.category).filter(Boolean)));
                   uniqueCats.forEach(cat => { 
                %>
                <li><a href="/blog?category=<%= encodeURIComponent(cat) %>" class="<%= filters && filters.category === cat ? 'active' : '' %>"><%= cat %></a></li>
                <% }) %>
            </ul>
        </aside>
    </div>

    <%- include('../partials/footer') %>

    <script>
        const searchInput = document.getElementById('searchInput');
        const searchSpinner = document.getElementById('searchSpinner');
        const postsList = document.getElementById('posts-list');
        let searchTimeout = null;

        searchInput.addEventListener('input', (e) => {
            clearTimeout(searchTimeout);
            searchSpinner.style.display = 'block';

            searchTimeout = setTimeout(async () => {
                const keyword = e.target.value;
                const url = new URL(window.location.href);
                url.searchParams.set('search', keyword);
                url.searchParams.set('ajax', '1');

                try {
                    const res = await fetch(url.toString(), {
                        headers: { 'Accept': 'application/json' }
                    });
                    const data = await res.json();
                    
                    // Update URL display without reload
                    const displayUrl = new URL(window.location.href);
                    if(keyword) displayUrl.searchParams.set('search', keyword);
                    else displayUrl.searchParams.delete('search');
                    window.history.pushState({}, '', displayUrl.toString());

                    renderPosts(data.posts, data.filters);
                } catch(e) {
                    console.error("Search failed", e);
                } finally {
                    searchSpinner.style.display = 'none';
                }
            }, 500);
        });

        function renderPosts(posts, filters) {
            let html = '';
            if (Object.keys(filters || {}).length > 0) {
                html += `
                    <div class="active-filter-badge">
                        <span><i class="fas fa-filter"></i> Đang lọc kết quả</span>
                        <a href="/blog" title="Xóa lọc"><i class="fas fa-times-circle"></i></a>
                    </div>`;
            }

            if (posts.length === 0) {
                html += `
                    <div style="text-align:center; padding: 40px; background:#fff; border-radius:12px; border:1px dashed #cbd5e1;">
                        <i class="fas fa-search" style="font-size:2rem; color:#94a3b8; display:block; margin-bottom:15px;"></i>
                        <p style="color:#64748b;">Không tìm thấy bài viết nào phù hợp.</p>
                    </div>`;
            } else {
                posts.forEach(post => {
                    const date = new Date(post.created_at).toLocaleDateString('vi-VN');
                    html += `
                        <article class="post-card">
                            ${post.is_pinned ? '<i class="fas fa-thumbtack post-pinned" title="Bài ghim"></i>' : ''}
                            <div class="post-meta">
                                <a href="/blog?category=${encodeURIComponent(post.category || '')}" class="tag-category">${post.category || 'Không phân loại'}</a>
                                ${post.series ? `<a href="/blog?series=${encodeURIComponent(post.series)}" class="tag-series"><i class="fas fa-layer-group"></i> ${post.series}</a>` : ''}
                                <a href="/blog?author=${post.author_id}" style="color: #64748b;"><i class="far fa-user"></i> ${post.author_name || 'Admin'}</a>
                                <span><i class="far fa-calendar-alt"></i> ${date}</span>
                            </div>
                            <h2 class="post-title"><a href="/post/${post.id}">${post.title}</a></h2>
                            <div class="engagement-bar">
                                <span class="eng-item"><i class="far fa-eye"></i> ${post.views || 0}</span>
                                <span class="eng-item"><i class="far fa-heart"></i> ${post.likes || 0}</span>
                                <span class="eng-item"><i class="far fa-comment"></i> ${post.comment_count || 0}</span>
                            </div>
                        </article>`;
                });
            }
            postsList.innerHTML = html;
        }
    </script>
    </script>
</body>
</html>
