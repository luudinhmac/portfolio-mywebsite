<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %> - Lưu Đình Mác</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Quill.js Theme CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .post-layout { max-width: 800px; margin: 70px auto 40px; padding: 0 20px; }
        .post-header { margin-bottom: 0px !important; text-align: center; line-height: 1.1; }
        .post-title { font-size: 1.85rem; font-weight: 800; color: #1e293b; line-height: 1.1; margin-bottom: 0px !important; margin-top: 0 !important; }
        .post-meta { display: flex; justify-content: center; align-items: center; gap: 12px; font-size: 0.95rem; color: #64748b; margin-bottom: 8px; }
        .tag-category { background: #e0f2fe; color: #0284c7; padding: 4px 12px; border-radius: 20px; font-weight: 600; }
        .post-body { font-size: 1.1rem; line-height: 1.8; color: #334155; margin-bottom: 60px; padding-top: 0 !important; margin-top: -15px !important; }
        .ql-editor { padding-top: 0 !important; padding-left: 0 !important; padding-right: 0 !important; }
        .ql-editor > *:first-child { margin-top: 0 !important; }
        /* Hide leading empty paragraphs common in Quill */
        .ql-editor > p:first-child:empty, 
        .ql-editor > p:first-child > br:only-child { display: none !important; }
        .post-body img { max-width: 100%; border-radius: 8px; margin: 20px 0; }
        .comments-section { border-top: 1px solid #e2e8f0; padding-top: 40px; }
        .comment-form { background: #f8fafc; padding: 25px; border-radius: 12px; margin-bottom: 40px; }
        
        /* Series Navigation Styles */
        .series-nav { display: flex; justify-content: space-between; gap: 20px; border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0; padding: 30px 0; margin-bottom: 40px; }
        .series-nav-item { flex: 1; display: flex; flex-direction: column; text-decoration: none; transition: transform 0.2s; }
        .series-nav-item:hover { transform: translateY(-2px); }
        .series-nav-item.prev { align-items: flex-start; text-align: left; }
        .series-nav-item.next { align-items: flex-end; text-align: right; }
        .series-nav-label { font-size: 0.85rem; color: #64748b; margin-bottom: 5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        .series-nav-title { font-size: 1.1rem; color: #0f172a; font-weight: 700; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .series-nav-item:hover .series-nav-title { color: var(--primary); }
    </style>
</head>
<body class="bg-color">

    <%- include('../partials/header') %>

    <div class="post-layout">
        <article id="article">
            <header class="post-header">
                <div class="post-meta">
                    <a href="/blog?category=<%= encodeURIComponent(post.category || '') %>" class="tag-category"><%= post.category || 'Không Phân Loại' %></a>
                    <% if (post.series) { %>
                        <a href="/blog?series=<%= encodeURIComponent(post.series) %>" style="color: #64748b;"><i class="fas fa-layer-group"></i> <%= post.series %></a>
                    <% } %>
                    <a href="/blog?author=<%= post.author_id %>" style="color: #64748b;"><i class="far fa-user"></i> <%= post.author_name || 'Admin' %></a>
                    <span><i class="far fa-calendar-alt"></i> <%= new Date(post.created_at).toLocaleDateString('vi-VN') %></span>
                    <span style="margin-left:15px; color:#94a3b8;"><i class="far fa-eye"></i> <%= post.views || 0 %> lượt xem</span>
                    <button id="btnLike" class="eng-btn" style="margin-left:15px; background:none; border:none; cursor:pointer; color:#94a3b8; font-family:inherit; font-size:1rem; padding:0; display:inline-flex; align-items:center; gap:5px;">
                        <i class="far fa-heart" id="heartIcon"></i> <span id="likeCount"><%= post.likes || 0 %></span> yêu thích
                    </button>
                </div>
                <h1 class="post-title"><%= post.title %></h1>
            </header>
            
            <div class="post-body ql-editor">
                <%- post.content %>
            </div>
        </article>

        <% if (typeof locals.prevPost !== 'undefined' && typeof locals.nextPost !== 'undefined' && (locals.prevPost || locals.nextPost)) { %>
            <nav class="series-nav">
                <% if (locals.prevPost) { %>
                    <a href="/post/<%= prevPost.id %>" class="series-nav-item prev">
                        <span class="series-nav-label"><i class="fas fa-arrow-left"></i> Bài trước</span>
                        <span class="series-nav-title"><%= prevPost.title %></span>
                    </a>
                <% } else { %>
                    <div style="flex: 1;"></div>
                <% } %>

                <% if (locals.nextPost) { %>
                    <a href="/post/<%= nextPost.id %>" class="series-nav-item next">
                        <span class="series-nav-label">Bài tiếp theo <i class="fas fa-arrow-right"></i></span>
                        <span class="series-nav-title"><%= nextPost.title %></span>
                    </a>
                <% } else { %>
                    <div style="flex: 1;"></div>
                <% } %>
            </nav>
        <% } %>
        
        <section class="comments-section">
            <h3 class="comments-title">Bình Luận</h3>
            
            <div class="comment-form">
                <form id="formComment">
                    <input type="hidden" id="postId" value="<%= post.id %>">
                    <div style="display: flex; gap: 20px; margin-bottom: 15px;">
                        <input type="text" id="cName" placeholder="Tên của bạn *" required style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px;">
                        <input type="email" id="cEmail" placeholder="Email *" required style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px;">
                    </div>
                    <textarea id="cBody" rows="4" placeholder="Nhập bình luận của bạn..." required style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px;"></textarea>
                    <button type="submit" class="btn-primary" style="margin-top:15px; width: auto; padding: 10px 30px;">Gửi Bình Luận</button>
                    <p id="cMsg" style="margin-top:10px; color: green; display:none;"></p>
                </form>
            </div>
            
            <div class="comment-list" id="commentList"></div>
        </section>
    </div>

    <%- include('../partials/footer') %>

    <script src="/js/script.js"></script>
    <script>
        const postId = document.getElementById('postId').value;

        async function loadComments() {
            try {
                const cRes = await fetch(`/api/comments/${postId}`);
                const comments = await cRes.json();
                const list = document.getElementById('commentList');
                list.innerHTML = '';
                
                if (comments.length === 0) {
                    list.innerHTML = '<p>Chưa có bình luận nào. Hãy là người đầu tiên!</p>';
                    return;
                }
                
                comments.forEach(c => {
                    const cDate = new Date(c.created_at).toLocaleString('vi-VN');
                    list.insertAdjacentHTML('beforeend', `
                        <div style="background: white; border: 1px solid #e2e8f0; padding: 20px; border-radius: 12px; margin-bottom: 20px;">
                            <div style="font-weight: 600; color: #1e293b;">${c.author_name}</div>
                            <div style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 15px;">${cDate}</div>
                            <div style="color: #475569;">${c.content.replace(/</g, "&lt;")}</div>
                        </div>
                    `);
                });
            } catch(e) {}
        }
        
        document.getElementById('formComment').addEventListener('submit', async (e) => {
            e.preventDefault();
            const payload = {
                post_id: parseInt(postId),
                author_name: document.getElementById('cName').value,
                author_email: document.getElementById('cEmail').value,
                content: document.getElementById('cBody').value
            };
            
            try {
                await fetch('/api/comments', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                e.target.reset();
                loadComments();
            } catch(err) {}
        });

        const likeCount = document.getElementById('likeCount');
        const btnLike = document.getElementById('btnLike');
        const heartIcon = document.getElementById('heartIcon');

        async function checkLikeStatus() {
            const user = sessionStorage.getItem('currentUser');
            if(!user) return;
            try {
                const res = await fetch(`/api/posts/${postId}/like-status`);
                const data = await res.json();
                updateLikeUI(data.liked);
            } catch(e) {}
        }

        function updateLikeUI(liked) {
            if (liked) {
                heartIcon.classList.remove('far');
                heartIcon.classList.add('fas');
                btnLike.style.color = '#ef4444';
            } else {
                heartIcon.classList.remove('fas');
                heartIcon.classList.add('far');
                btnLike.style.color = '#94a3b8';
            }
        }

        btnLike.addEventListener('click', async () => {
            const user = sessionStorage.getItem('currentUser');
            if(!user) {
                // Mở modal đăng nhập (trigger-login-modal đã có class này trong header.ejs)
                const loginOverlay = document.getElementById('loginOverlay');
                if (loginOverlay) {
                    loginOverlay.classList.add('active');
                    document.body.style.overflow = 'hidden';
                } else {
                    alert('Vui lòng đăng nhập để thực hiện tính năng này!');
                }
                return;
            }
            try {
                const res = await fetch(`/api/posts/${postId}/like`, {
                    method: 'POST'
                });
                const data = await res.json();
                updateLikeUI(data.liked);
                
                // Update count
                let current = parseInt(likeCount.innerText);
                likeCount.innerText = data.liked ? current + 1 : Math.max(0, current - 1);
            } catch(e) {}
        });

        document.addEventListener('DOMContentLoaded', () => {
            loadComments();
            checkLikeStatus();
        });
    </script>
</body>
</html>
