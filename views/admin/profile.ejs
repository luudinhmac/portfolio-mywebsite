<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hồ Sơ Của Tôi - Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .input-group { position: relative; }
        .toggle-password { position: absolute; right: 15px; top: 40px; cursor: pointer; color: #64748b; }
        .toggle-password:hover { color: #1e293b; }
    </style>
</head>
<body>
    <%- include('../partials/admin-header', { currentPage: 'profile' }) %>

    <div class="admin-page">
        <main class="admin-content">
            <div class="page-header">
                <div>
                    <h1><i class="fas fa-user-circle" style="color:var(--primary);margin-right:10px;"></i>Hồ Sơ Của Tôi</h1>
                    <p>Quản lý thông tin bảo mật và cá nhân.</p>
                </div>
            </div>

            <div id="alertMsg" class="alert"></div>

            <div style="display: flex; gap: 30px; align-items: flex-start; flex-wrap: wrap;">
                <!-- Profile Edit -->
                <div class="form-card" style="flex: 1; min-width: 350px;">
                    <h3>Thông Tin Cá Nhân</h3>
                    <form id="profileForm" style="margin-top:20px;">
                        <div class="form-group">
                            <label>Họ Tên</label>
                            <input type="text" id="fullname" class="form-control" placeholder="Tên hiển thị">
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="email" class="form-control" placeholder="Email">
                        </div>
                        <div class="form-row" style="display:flex; gap:20px; margin-bottom: 22px;">
                            <div class="form-group" style="flex:1; margin-bottom:0;">
                                <label>Số điện thoại</label>
                                <input type="text" id="phone" class="form-control" placeholder="SĐT">
                            </div>
                            <div class="form-group" style="flex:1; margin-bottom:0;">
                                <label>Ngày sinh</label>
                                <input type="date" id="birthday" class="form-control">
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Nơi sống</label>
                            <input type="text" id="address" class="form-control" placeholder="Địa chỉ">
                        </div>
                        <div class="form-group">
                            <label>Nghề nghiệp</label>
                            <input type="text" id="profession" class="form-control" placeholder="Vd: System Engineer">
                        </div>
                        <div class="form-group">
                            <label>Ảnh đại diện</label>
                            <input type="file" id="avatarFile" class="form-control" accept="image/*">
                            <input type="hidden" id="avatarUrl" value="">
                            <div style="margin-top:10px;">
                                <img id="avatarPreview" src="/img/default-avatar.png" style="width:60px;height:60px;border-radius:50%;object-fit:cover;border:1px solid #cbd5e1;">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary" id="btnProfile"><i class="fas fa-save"></i> Lưu Thông Tin</button>
                    </form>
                </div>

                <!-- Password Reset -->
                <div class="form-card" style="flex: 1; min-width: 350px;">
                    <h3>Đổi Mật Khẩu</h3>
                    <form id="passForm" style="margin-top:20px;">
                        <div class="form-group input-group">
                            <label>Mật Khẩu Hiện Tại <span class="required">*</span></label>
                            <input type="password" id="old_password" class="form-control" required>
                            <i class="far fa-eye toggle-password" id="tOldPass"></i>
                        </div>
                        <div class="form-group input-group">
                            <label>Mật Khẩu Mới <span class="required">*</span></label>
                            <input type="password" id="new_password" class="form-control" required>
                            <i class="far fa-eye toggle-password" id="tNewPass"></i>
                        </div>
                        <button type="submit" class="btn btn-warning" id="btnPass"><i class="fas fa-key"></i> Đổi Mật Khẩu</button>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <%- include('../partials/admin-footer') %>
    <script src="/js/admin-layout.js"></script>
    <script>
        document.getElementById('tOldPass').addEventListener('click', function() {
            const input = document.getElementById('old_password');
            if(input.type === 'password'){ input.type = 'text'; this.classList.replace('fa-eye', 'fa-eye-slash'); }
            else { input.type = 'password'; this.classList.replace('fa-eye-slash', 'fa-eye'); }
        });

        document.getElementById('tNewPass').addEventListener('click', function() {
            const input = document.getElementById('new_password');
            if(input.type === 'password'){ input.type = 'text'; this.classList.replace('fa-eye', 'fa-eye-slash'); }
            else { input.type = 'password'; this.classList.replace('fa-eye-slash', 'fa-eye'); }
        });

        async function loadData() {
            try {
                const res = await fetch('/api/users', { headers: { 'Authorization': `Bearer ${getToken()}` }});
                const users = await res.json();
                const u = users.find(x => x.id === window.currentUser.id);
                if(u) {
                    document.getElementById('fullname').value = u.fullname || '';
                    document.getElementById('email').value = u.email || '';
                    document.getElementById('profession').value = u.profession || '';
                    document.getElementById('phone').value = u.phone || '';
                    document.getElementById('birthday').value = u.birthday || '';
                    document.getElementById('address').value = u.address || '';
                    if(u.avatar) {
                        document.getElementById('avatarUrl').value = u.avatar;
                        document.getElementById('avatarPreview').src = u.avatar;
                    } else {
                        document.getElementById('avatarPreview').src = '/img/default-avatar.png';
                    }
                }
            } catch(e) {}
        }

        document.getElementById('avatarFile').addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                    document.getElementById('avatarPreview').style.display = 'block';
                }
                reader.readAsDataURL(file);
            }
        });

        document.getElementById('profileForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnProfile');
            btn.disabled = true;

            let finalAvatarUrl = document.getElementById('avatarUrl').value;
            const fileInput = document.getElementById('avatarFile');

            try {
                if(fileInput.files.length > 0) {
                    const formData = new FormData();
                    formData.append('avatar', fileInput.files[0]);
                    const upRes = await fetch('/api/users/upload-avatar', {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${getToken()}` },
                        body: formData
                    });
                    if(upRes.ok) {
                        const upData = await upRes.json();
                        finalAvatarUrl = upData.url;
                    } else {
                        showAlert('alertMsg', 'Lỗi tải ảnh lên. Chắc chắn ảnh < 5MB', 'error');
                        btn.disabled = false;
                        return;
                    }
                }

                const res = await fetch(`/api/users/${window.currentUser.id}/profile`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
                    body: JSON.stringify({
                        fullname: document.getElementById('fullname').value,
                        email: document.getElementById('email').value,
                        profession: document.getElementById('profession').value,
                        phone: document.getElementById('phone').value,
                        birthday: document.getElementById('birthday').value,
                        address: document.getElementById('address').value,
                        avatar: finalAvatarUrl,
                    })
                });
                if(res.ok) showAlert('alertMsg', 'Đã lưu thông tin hồ sơ!', 'success');
                else { const d = await res.json(); showAlert('alertMsg', d.error, 'error'); }
            } catch(e) { showAlert('alertMsg', 'Lỗi kết nối', 'error'); }
            finally { btn.disabled = false; }
        });

        document.getElementById('passForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const res = await fetch(`/api/users/${window.currentUser.id}/password`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
                    body: JSON.stringify({ 
                        old_password: document.getElementById('old_password').value,
                        new_password: document.getElementById('new_password').value 
                    })
                });
                if(res.ok) {
                    document.getElementById('passForm').reset();
                    showAlert('alertMsg', 'Đã đổi mật khẩu thành công!', 'success');
                } else { const d = await res.json(); showAlert('alertMsg', d.error, 'error'); }
            } catch(e) { showAlert('alertMsg', 'Lỗi kết nối', 'error'); }
        });

        document.addEventListener('DOMContentLoaded', loadData);
    </script>
</body>
</html>
