<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thêm User Mới - Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .input-group { position: relative; }
        .toggle-password {
            position: absolute; right: 15px; top: 40px; cursor: pointer; color: #64748b;
        }
        .toggle-password:hover { color: #1e293b; }
    </style>
</head>
<body>
    <%- include('../partials/admin-header', { currentPage: 'manage_users' }) %>

    <div class="admin-page">
        <main class="admin-content">
            <div class="page-header">
                <div>
                    <h1><i class="fas fa-user-plus" style="color:var(--primary);margin-right:10px;"></i>Thêm User Mới</h1>
                    <p>Tạo tài khoản quản trị mới cho hệ thống.</p>
                </div>
                <a href="/manage_users" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay Lại
                </a>
            </div>

            <div class="form-card" style="max-width: 600px; margin: 0 auto;">
                <div id="alertMsg" class="alert"></div>
                <form id="userForm">
                    <div class="form-group">
                        <label for="username">Tên Đăng Nhập <span class="required">*</span></label>
                        <input type="text" id="username" class="form-control" required placeholder="Nhập tên đăng nhập... (vd: admin2)">
                    </div>

                    <div class="form-group">
                        <label for="email">Email <span class="required">*</span></label>
                        <input type="email" id="email" class="form-control" required placeholder="example@email.com">
                    </div>
                    
                    <div class="form-group">
                        <label for="fullname">Họ Tên</label>
                        <input type="text" id="fullname" class="form-control" placeholder="Nguyễn Văn A">
                    </div>

                    <div class="form-group input-group">
                        <label for="password">Mật Khẩu <span class="required">*</span></label>
                        <input type="password" id="password" class="form-control" required placeholder="Nhập mật khẩu an toàn...">
                        <i class="far fa-eye toggle-password" id="togglePass"></i>
                    </div>

                    <div class="form-group input-group">
                        <label for="confirm_password">Xác Nhận Mật Khẩu <span class="required">*</span></label>
                        <input type="password" id="confirm_password" class="form-control" required placeholder="Nhập lại mật khẩu...">
                        <i class="far fa-eye toggle-password" id="toggleConfirmPass"></i>
                    </div>
                    
                    <div class="form-group">
                        <label for="role">Vai Trò</label>
                        <select id="role" class="form-control">
                            <option value="editor">Editor (Đăng bài)</option>
                            <option value="admin">Admin (Toàn quyền)</option>
                        </select>
                    </div>
                    <div style="margin-top: 30px;">
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fas fa-save"></i> Tạo Tài Khoản
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <%- include('../partials/admin-footer') %>

    <script src="/js/admin-layout.js"></script>
    <script>
        // Toggle password visibility
        document.getElementById('togglePass').addEventListener('click', function (e) {
            const passInput = document.getElementById('password');
            if (passInput.type === 'password') {
                passInput.type = 'text';
                this.classList.remove('fa-eye');
                this.classList.add('fa-eye-slash');
            } else {
                passInput.type = 'password';
                this.classList.remove('fa-eye-slash');
                this.classList.add('fa-eye');
            }
        });

        document.getElementById('toggleConfirmPass').addEventListener('click', function (e) {
            const passInput = document.getElementById('confirm_password');
            if (passInput.type === 'password') {
                passInput.type = 'text';
                this.classList.remove('fa-eye');
                this.classList.add('fa-eye-slash');
            } else {
                passInput.type = 'password';
                this.classList.remove('fa-eye-slash');
                this.classList.add('fa-eye');
            }
        });

        document.getElementById('userForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            const username = document.getElementById('username').value;
            const email = document.getElementById('email').value;
            const fullname = document.getElementById('fullname').value;
            const password = document.getElementById('password').value;
            const confirm_password = document.getElementById('confirm_password').value;
            const role = document.getElementById('role').value;
            
            if (password !== confirm_password) {
                return showAlert('Mật khẩu xác nhận không khớp!', 'error');
            }

            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';
            btn.disabled = true;

            try {
                const res = await fetch('/api/users', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${getToken()}` 
                    },
                    body: JSON.stringify({ username, email, fullname, password, role })
                });
                
                const data = await res.json();
                if (res.ok) {
                    window.location.href = '/manage_users';
                } else {
                    showAlert(data.error || 'Lỗi lưu dữ liệu', 'error');
                }
            } catch (err) {
                showAlert('Không thể kết nối đến máy chủ', 'error');
            } finally {
                btn.innerHTML = '<i class="fas fa-save"></i> Tạo Tài Khoản';
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>
