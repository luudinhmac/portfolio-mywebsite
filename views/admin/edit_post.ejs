<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Bài Viết - Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <%- include('../partials/admin-header', { currentPage: 'edit_post' }) %>

    <div class="admin-page">
        <main class="admin-content">
            <div class="page-header">
                <div>
                    <h1><i class="fas fa-pen" style="color:var(--primary);margin-right:10px;"></i>Sửa Bài Viết</h1>
                    <p id="postMeta">Đang tải...</p>
                </div>
                <a href="/manage_posts" class="btn btn-secondary">Quay lại</a>
            </div>

            <div id="alertMsg" class="alert"></div>

            <div class="form-card">
                <form id="postForm">
                    <input type="hidden" id="postId" value="<%= postId %>">
                    <div class="form-group">
                        <label for="title">Tiêu Đề Bài Viết *</label>
                        <input type="text" id="title" class="form-control" required placeholder="Nhập tiêu đề...">
                    </div>
                    <div class="form-row" style="display:flex; gap:20px;">
                        <div class="form-group" style="flex:1;">
                            <label for="category_id">Danh Mục</label>
                            <select id="category_id" class="form-control">
                                <option value="">-- Tùy chọn --</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex:1;">
                            <label for="series">Series</label>
                            <input type="text" id="series" class="form-control" placeholder="Tùy chọn">
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="checkbox" id="isPinned"> <label for="isPinned">Ghim bài viết</label>
                    </div>
                    <div class="form-group">
                        <label>Nội Dung</label>
                        <div id="editor-container" style="height:400px;"></div>
                    </div>
                    <button type="submit" class="btn btn-success" id="submitBtn">Lưu Thay Đổi</button>
                </form>
            </div>
        </main>
    </div>

    <%- include('../partials/admin-footer') %>

    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="/js/admin-layout.js"></script>
    <script>
        const quill = new Quill('#editor-container', { theme: 'snow' });
        const postId = document.getElementById('postId').value;

        async function loadPost() {
            try {
                // Fetch cats first so we can assign the matching one later
                const cRes = await fetch('/api/categories');
                const cats = await cRes.json();
                const sel = document.getElementById('category_id');
                cats.forEach(c => {
                    sel.insertAdjacentHTML('beforeend', `<option value="${c.id}">${c.name}</option>`);
                });

                const res = await fetch(`/api/posts/${postId}`);
                if (!res.ok) throw new Error('Not found');
                const post = await res.json();
                document.getElementById('title').value = post.title;
                document.getElementById('category_id').value = post.category_id || "";
                document.getElementById('series').value = post.series;
                document.getElementById('isPinned').checked = !!post.is_pinned;
                quill.root.innerHTML = post.content || '';
                document.getElementById('postMeta').textContent = `Đang sửa bài: "${post.title}"`;
            } catch (err) {
                document.getElementById('postMeta').textContent = 'Lỗi tải bài viết.';
            }
        }

        document.getElementById('postForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const payload = {
                title: document.getElementById('title').value,
                category_id: document.getElementById('category_id').value,
                series: document.getElementById('series').value,
                is_pinned: document.getElementById('isPinned').checked,
                content: quill.root.innerHTML
            };
            const res = await fetch(`/api/posts/${postId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
                body: JSON.stringify(payload)
            });
            if (res.ok) window.location.href = '/manage_posts';
        });

        document.addEventListener('DOMContentLoaded', loadPost);
    </script>
</body>
</html>
