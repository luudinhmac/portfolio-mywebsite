<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tạo Bài Viết - Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <%- include('../partials/admin-header', { currentPage: 'create_post' }) %>

    <div class="admin-page">
        <main class="admin-content">
            <div class="page-header">
                <div>
                    <h1><i class="fas fa-plus-circle" style="color:var(--primary);margin-right:10px;"></i>Tạo Bài Viết Mới</h1>
                    <p>Soạn và xuất bản bài viết mới lên blog.</p>
                </div>
                <div style="display:flex;gap:12px;align-items:center;">
                    <label for="wordFile" class="btn-import" id="importBtn" style="cursor:pointer; background:#10b981; color:#fff; padding:8px 15px; border-radius:6px;">
                        <i class="fas fa-file-word"></i> Import từ Word
                    </label>
                    <input type="file" id="wordFile" accept=".docx" style="display:none;">
                    <a href="/manage_posts" class="btn btn-secondary">Quay lại</a>
                </div>
            </div>

            <div id="alertMsg" class="alert"></div>

            <div class="form-card">
                <form id="postForm">
                    <div class="form-group">
                        <label for="title">Tiêu Đề Bài Viết *</label>
                        <input type="text" id="title" class="form-control" required placeholder="Nhập tiêu đề...">
                    </div>
                    <div class="form-row" style="display:flex; gap:20px;">
                        <div class="form-group" style="flex:1;">
                            <label for="category">Danh Mục *</label>
                            <select id="category" class="form-control" required>
                                <option value="">-- Chọn --</option>
                                <option value="System">System</option>
                                <option value="DevOps">DevOps</option>
                                <option value="VMware">VMware</option>
                                <option value="Linux">Linux</option>
                                <option value="Cloud">Cloud</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex:1;">
                            <label for="series">Series</label>
                            <input type="text" id="series" class="form-control" placeholder="Tùy chọn">
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="checkbox" id="isPinned"> <label for="isPinned">Ghim bài viết</label>
                    </div>
                    <div class="form-group">
                        <label>Nội Dung</label>
                        <div id="editor-container" style="height:400px;"></div>
                    </div>
                    <button type="submit" class="btn btn-primary" id="submitBtn">Xuất Bản</button>
                </form>
            </div>
        </main>
    </div>

    <%- include('../partials/admin-footer') %>

    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="/js/admin-layout.js"></script>
    <script>
        const quill = new Quill('#editor-container', { theme: 'snow' });

        document.getElementById('wordFile').addEventListener('change', async (e) => {
            if (!e.target.files.length) return;
            const formData = new FormData();
            formData.append('document', e.target.files[0]);
            const res = await fetch('/api/upload-word', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${getToken()}` },
                body: formData
            });
            const json = await res.json();
            if (res.ok) quill.root.innerHTML += json.html;
        });

        document.getElementById('postForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const payload = {
                title: document.getElementById('title').value,
                category: document.getElementById('category').value,
                series: document.getElementById('series').value,
                is_pinned: document.getElementById('isPinned').checked,
                content: quill.root.innerHTML
            };
            const res = await fetch('/api/posts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
                body: JSON.stringify(payload)
            });
            if (res.ok) window.location.href = '/manage_posts';
        });
    </script>
</body>
</html>
