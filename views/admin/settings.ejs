<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cài Đặt Hệ Thống - Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .settings-card {
            background: var(--bg-color);
            border-radius: 16px;
            padding: 30px;
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-md);
            max-width: 800px;
            margin: 0 auto;
        }
        .setting-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid var(--border-color);
        }
        .setting-item:last-child {
            border-bottom: none;
        }
        .setting-info h4 {
            margin-bottom: 5px;
            color: var(--text-main);
        }
        .setting-info p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .setting-control {
            min-width: 150px;
            display: flex;
            justify-content: flex-end;
        }
        .toggle-switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 26px;
        }
        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #cbd5e1;
            transition: .4s;
            border-radius: 34px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        input:checked + .slider {
            background-color: var(--primary);
        }
        input:checked + .slider:before {
            transform: translateX(24px);
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="section" style="padding-top: 120px; min-height: 100vh;">
        <div class="section-container">
            <div class="section-header">
                <h2><i class="fas fa-cog" style="color:var(--primary); margin-right: 15px;"></i>Cài đặt hệ thống</h2>
                <p class="section-desc">Tùy chỉnh giao diện và ngôn ngữ theo sở thích của bạn.</p>
            </div>

            <div class="settings-card">
                <!-- Theme Setting -->
                <div class="setting-item">
                    <div class="setting-info">
                        <h4>Chế độ tối (Dark Mode)</h4>
                        <p>Sử dụng giao diện tối màu để giảm mỏi mắt.</p>
                    </div>
                    <div class="setting-control">
                        <label class="toggle-switch">
                            <input type="checkbox" id="darkModeToggle">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>

                <!-- Language Setting -->
                <div class="setting-item">
                    <div class="setting-info">
                        <h4>Ngôn ngữ hiển thị</h4>
                        <p>Chọn ngôn ngữ chính cho giao diện người dùng.</p>
                    </div>
                    <div class="setting-control">
                        <select id="languageSelect" class="form-control" style="padding: 5px 10px; border-radius: 8px;">
                            <option value="vi">Tiếng Việt</option>
                            <option value="en">English</option>
                        </select>
                    </div>
                </div>

                <!-- Other Placeholders -->
                <div class="setting-item">
                    <div class="setting-info">
                        <h4>Thông báo trình duyệt</h4>
                        <p>Nhận thông báo khi có bài viết hoặc bình luận mới.</p>
                    </div>
                    <div class="setting-control">
                        <label class="toggle-switch">
                            <input type="checkbox">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>
            </div>
            
            <div style="text-align: center; margin-top: 30px;">
                <button id="saveSettings" class="btn-primary" style="padding: 10px 40px; border: none; font-family: inherit;">Lưu thay đổi</button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const darkModeToggle = document.getElementById('darkModeToggle');
            const languageSelect = document.getElementById('languageSelect');
            const saveBtn = document.getElementById('saveSettings');

            // Load current settings
            const isDark = document.body.classList.contains('dark-mode');
            darkModeToggle.checked = isDark;

            const savedLang = localStorage.getItem('language') || 'vi';
            languageSelect.value = savedLang;

            // Save Functionality
            saveBtn.addEventListener('click', () => {
                // Theme is already handled by header toggle, but we sync here too
                const darkValue = darkModeToggle.checked;
                if (darkValue) {
                    document.body.classList.add('dark-mode');
                    localStorage.setItem('theme', 'dark');
                } else {
                    document.body.classList.remove('dark-mode');
                    localStorage.setItem('theme', 'light');
                }

                // Language
                localStorage.setItem('language', languageSelect.value);

                // Show success alert (using existing alert logic or simple alert)
                alert('Đã lưu tất cả cài đặt!');
                window.location.reload();
            });

            // Sync with navbar toggle if user toggles there
            window.addEventListener('storage', (e) => {
                if (e.key === 'theme') {
                    darkModeToggle.checked = e.newValue === 'dark';
                }
            });
        });
    </script>
</body>
</html>
